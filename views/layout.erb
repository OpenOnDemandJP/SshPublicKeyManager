<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>SSH Public Key Manager</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body                           { background-color: <%= h @appearance[:body_bg] %>     !important; }
    .navbar                        { background-color: <%= h @appearance[:navbar_bg] %>    !important; }
    .navbar .navbar-brand,
    .navbar .nav-link              { color:            <%= h @appearance[:navbar_text] %>  !important; }
    .text-bg-primary               { background-color: <%= h @appearance[:primary_color] %> !important;
                                     color:            <%= h @appearance[:primary_text] %>  !important; }
    .btn-primary                   { background-color: <%= h @appearance[:primary_color] %> !important;
                                     border-color:     <%= h @appearance[:primary_color] %> !important;
                                     color:            <%= h @appearance[:primary_text] %>  !important; }
  </style>
</head>
<body>
  <nav class="navbar mb-4">
    <div class="container">
      <a class="navbar-brand" href="<%= url('/') %>">SSH Public Key Manager</a>
      <a class="nav-link text-white" href="/pun/sys/dashboard">Open OnDemand</a>
    </div>
  </nav>
  <main class="container" style="max-width: 960px;">
    <%= yield %>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
